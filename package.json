{
  "name": "word-ai-addin",
  "version": "1.0.0",
  "description": "AI 驱动的 Word 写作助手插件",
  "scripts": {
    "dev": "office-addin-dev-certs install && webpack serve --mode development",
    "build": "webpack --mode production",
    "start": "npm run dev",
    "validate": "office-addin-manifest validate manifest.xml",
    "sideload": "office-addin-debugging start manifest.xml"
  },
  "dependencies": {
    "@microsoft/office-js": "^1.1.0"
  },
  "devDependencies": {
    "office-addin-dev-certs": "^1.8.0",
    "office-addin-debugging": "^4.4.0",
    "office-addin-manifest": "^1.7.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "copy-webpack-plugin": "^11.0.0",
    "html-webpack-plugin": "^5.5.3"
  }
}
